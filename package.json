{
  "name": "tailwind-nextjs-starter-blog",
  "version": "2.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "next dev --turbopack -p 3456",
    "dev": "cross-env INIT_CWD=$PWD contentlayer2 build && next dev --turbopack -p 3456",
    "build": "cross-env INIT_CWD=$PWD next build --turbopack && cross-env NODE_OPTIONS='--experimental-strip-types --experimental-json-modules' node ./scripts/postbuild.mjs",
    "serve": "next start",
    "analyze": "cross-env ANALYZE=true next build --turbopack",
    "lint": "eslint .",
    "postinstall": "test \"$SKIP_CONTENTLAYER_BUILD\" = 'true' || contentlayer2 build || true"
  },
  "dependencies": {
    "@next/bundle-analyzer": "latest",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "autoprefixer": "latest",
    "contentlayer2": "latest",
    "esbuild": "^0.25.0",
    "github-slugger": "^2.0.0",
    "gray-matter": "^4.0.3",
    "image-size": "1.2.1",
    "next": "latest",
    "next-contentlayer2": "latest",
    "next-themes": "^0.4.4",
    "playwright": "^1.59.1",
    "pliny": "latest",
    "postcss": "latest",
    "react": "latest",
    "react-dom": "latest",
    "reading-time": "1.5.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-citation": "^2.1.1",
    "rehype-katex": "^7.0.1",
    "rehype-mermaid": "^3.0.0",
    "rehype-preset-minify": "7.0.0",
    "rehype-prism-plus": "^2.0.0",
    "rehype-slug": "^6.0.0",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "tailwindcss": "latest",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@svgr/webpack": "^8.0.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/mdx": "latest",
    "@types/react": "latest",
    "@typescript-eslint/eslint-plugin": "latest",
    "@typescript-eslint/parser": "latest",
    "cross-env": "^7.0.3",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "husky": "^9.0.0",
    "lint-staged": "^13.0.0",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "typescript": "latest"
  },
  "dependencyResolutionNotes": {
    "security-overrides": "Temporary Yarn resolutions for transitive dependency advisories reported by GitHub Dependabot/npm audit. Remove entries one by one after upstream packages update, keeping `yarn npm audit --all --recursive` at 0 advisories."
  },
  "resolutions": {
    "@babel/runtime": "7.26.10",
    "@protobufjs/utf8": "1.1.1",
    "@opentelemetry/api": "1.4.1",
    "@opentelemetry/core": "1.13.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "0.39.1",
    "@opentelemetry/resources": "1.13.0",
    "@opentelemetry/sdk-trace-base": "1.13.0",
    "@opentelemetry/sdk-trace-node": "1.13.0",
    "@opentelemetry/semantic-conventions": "1.13.0",
    "ajv": "6.14.0",
    "brace-expansion@^1.1.7": "1.1.12",
    "brace-expansion@^2.0.1": "2.0.3",
    "dompurify": "3.4.0",
    "flatted": "3.4.2",
    "form-data": "2.5.5",
    "ip-address": "10.1.1",
    "js-yaml": "4.1.1",
    "minimatch@^9.0.4": "9.0.7",
    "picomatch@^4.0.2": "4.0.4",
    "postcss@8.4.31": "8.5.10",
    "protobufjs": "7.5.6",
    "svgo": "3.3.3",
    "tar": "7.5.11",
    "yaml": "2.8.3",
    "gray-matter@^4.0.3": "patch:gray-matter@npm%3A4.0.3#./.yarn/patches/gray-matter-npm-4.0.3-852ae4f34c.patch"
  },
  "lint-staged": {
    "*.+(js|jsx|ts|tsx)": [
      "eslint --fix"
    ],
    "*.+(js|jsx|ts|tsx|json|css|md|mdx)": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@3.6.1"
}
